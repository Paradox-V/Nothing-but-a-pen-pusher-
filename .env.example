# 服务器部署配置
DEPLOY_HOST=your_server_ip
DEPLOY_USER=ubuntu
DEPLOY_SSH_KEY_PATH=~/.ssh/id_rsa

# AI API 配置
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com/v1

# 管理员 Token（用于接口鉴权）
# 配置后，所有写接口（POST/PUT/DELETE）均需 Authorization: Bearer <token>
ADMIN_TOKEN=your_secure_token_here
#
# 安全说明：
#   前端将 Token 存储在浏览器 localStorage 中，存在 XSS 攻击窃取风险。
#   当前方案适用于内网/单用户场景。如需更高安全性：
#     1. 确保 DOMPurify 正常加载（已通过 CDN + SRI 引入）
#     2. 配置 CSP 头禁止 inline script：Content-Security-Policy "script-src 'self' cdn.jsdelivr.net"
#     3. 改用 HttpOnly cookie + 服务端 session 方案
#
# 开发模式：设置 FLASK_ENV=development 可在未配置 Token 时放行请求
